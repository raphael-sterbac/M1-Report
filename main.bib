@misc{slattery_hofmann-streicher_2026,
	title = {Hofmann-{Streicher} lifting of fibred categories},
	url = {http://arxiv.org/abs/2504.09520},
	doi = {10.48550/arXiv.2504.09520},
	abstract = {In 1997, Hofmann and Streicher introduced an explicit construction to lift a Grothendieck universe from the category of sets into the category of set-valued presheaves on a small category. More recently, Awodey presented an elegant functorial analysis of this construction in terms of the categorical nerve, the right adjoint to the functor that takes a presheaf to its category of elements; in particular, the categorical nerve’s functorial action on the universal small discrete fibration gives the generic family of the universe’s Hofmann–Streicher lifting. Inspired by Awodey’s analysis, we define a relative version of Hofmann–Streicher lifting in terms of the right pseudo-adjoint to the 2-functor given by postcomposition with a fibration. Finally, we construct a new 2-bifibration of fibrations in which the opcartesian and cartesian lifts arise from these pseudo-adjunctions.},
	language = {en},
	urldate = {2026-02-04},
	publisher = {arXiv},
	author = {Slattery, Andrew and Sterling, Jonathan},
	month = jan,
	year = {2026},
	note = {arXiv:2504.09520 [math]},
	keywords = {Mathematics - Category Theory, Computer Science - Logic in Computer Science},
	file = {PDF:/home/raphael/Zotero/storage/ELMHDZUE/Slattery and Sterling - 2026 - Hofmann-Streicher lifting of fibred categories.pdf:application/pdf},
}

